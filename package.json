{
  "name": "opencal",
  "version": "0.1.0",
  "description": "CLI Calendar/Gmail agent with provider-agnostic LLM orchestration",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/index.ts",
    "api:dev": "tsx apps/api/src/index.ts",
    "api:worker": "tsx apps/api/src/worker.ts",
    "api:worker:watch": "tsx apps/api/src/worker.ts --watch",
    "mobile:start": "npm --prefix apps/mobile run start",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "dependencies": {
    "@google/genai": "^1.19.0",
    "dotenv": "^16.5.0",
    "google-auth-library": "^9.15.1",
    "googleapis": "^150.0.1",
    "zod": "^3.24.2"
  },
  "optionalDependencies": {
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
