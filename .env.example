APP_ENV=development
ADMIN_API_KEY=
# Gemini works first out of the box. More providers can be added behind the same adapter interface.
LLM_PROVIDER=gemini
TOOL_RESULT_VERBOSITY=compact
GEMINI_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=

# Create these in Google Cloud Console -> APIs & Services -> Credentials -> OAuth client ID.
# CLI and API/mobile use different local callback routes.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:42813/oauth/callback
GOOGLE_OAUTH_API_REDIRECT_URI=http://127.0.0.1:8787/api/v1/auth/google/callback
API_PORT=8787
SESSION_TTL_DAYS=14
CONTEXT_WINDOW_LIMIT=128000
MAX_OUTPUT_TOKENS=2000
COMPACTION_THRESHOLD=0.8
OPENAI_MODEL=gpt-5-mini
GEMINI_MODEL=gemini-2.5-flash
GROQ_MODEL=llama-3.3-70b-versatile
