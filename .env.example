APP_ENV=development
API_VERSION=1.0.0
MIN_SUPPORTED_APP_VERSION=
STORAGE_BACKEND=file
JOB_BACKEND=file
DATABASE_URL=
REDIS_URL=
ADMIN_API_KEY=
STATE_ENCRYPTION_KEY=
# Gemini works first out of the box. More providers can be added behind the same adapter interface.
LLM_PROVIDER=gemini
TOOL_RESULT_VERBOSITY=compact
GEMINI_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=

# Create these in Google Cloud Console -> APIs & Services -> Credentials -> OAuth client ID.
# CLI and API/mobile use different local callback routes.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:42813/oauth/callback
GOOGLE_OAUTH_API_REDIRECT_URI=http://127.0.0.1:8787/api/v1/auth/google/callback
API_PORT=8787
SESSION_TTL_DAYS=14
IDEMPOTENCY_TTL_HOURS=24
JOB_MAX_ATTEMPTS=3
JOB_RETRY_DELAY_MS=30000
WORKER_POLL_INTERVAL_MS=5000
MAX_REQUEST_BODY_BYTES=1048576
CONTEXT_WINDOW_LIMIT=128000
MAX_OUTPUT_TOKENS=2000
COMPACTION_THRESHOLD=0.8
OPENAI_MODEL=gpt-5-mini
GEMINI_MODEL=gemini-2.5-flash
GROQ_MODEL=llama-3.3-70b-versatile
